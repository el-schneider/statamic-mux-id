{
    "name": "el-schneider/statamic-mux-id",
    "description": "A Statamic addon that integrates Mux Video API",
    "type": "statamic-addon",
    "license": "MIT",
    "authors": [
        {
            "name": "Jonas List",
            "email": "mail@jonaslist.de"
        }
    ],
    "autoload": {
        "psr-4": {
            "ElSchneider\\StatamicMuxId\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests"
        }
    },
    "require": {
        "php": "^8.3",
        "statamic/cms": "^6.0",
        "muxinc/mux-php": "^3.10"
    },
    "require-dev": {
        "laravel/pint": "^1.22",
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^4.0"
    },
    "extra": {
        "statamic": {
            "name": "Statamic Mux Id",
            "description": "Statamic Mux Id addon"
        },
        "laravel": {
            "providers": [
                "ElSchneider\\StatamicMuxId\\ServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pixelfear/composer-dist-plugin": true,
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "scripts": {
        "check": [
            "@pint:test",
            "@test"
        ],
        "fix": "@pint",
        "pint": "pint",
        "pint:test": "pint --test",
        "test": "pest"
    }
}
